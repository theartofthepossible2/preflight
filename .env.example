# Database (Supabase Postgres). MUST use a POOLER host (...pooler.supabase.com) — not the
# direct host (db.[ref].supabase.co), which is IPv6-only and fails on Vercel serverless.
#   Transaction pooler (port 6543) — ideal for serverless
#   Session pooler    (port 5432) — also works on Vercel (IPv4)
# Looks like: postgres://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:6543/postgres
# (code sets prepare:false, so either port is fine)
DATABASE_URL=

# Auth.js
# Generate: openssl rand -base64 32
AUTH_SECRET=
# GitHub OAuth app — register one at github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github (and your prod URL)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# GitHub App — the v0.4 scan runtime. On push/PR, GitHub calls our webhook; the backend
# downloads the repo at that commit, scans it, and posts the `preflight` check run that
# customers gate on. SEPARATE from the sign-in OAuth app above. Register at
# github.com/settings/apps/new.
#
# v0.4 permissions (least privilege for a read-only scanner that posts one check):
#   Contents: read        — download the repo tarball at a commit (never write)
#   Checks: write         — post the `preflight` check run
#   Pull requests: read   — receive pull_request events / read the PR head sha
#   Metadata: read        — mandatory (GitHub requires it of every app)
# Subscribe to events: Push, Pull request, Installation, Installation repositories.
# Webhook URL: https://<host>/api/github/webhooks.
#
# TRANSITIONAL: the legacy one-click setup path (writes a workflow file + repo secret) is
# still present until the deferred cutover removes it. While it remains you ALSO need
# Contents: write, Workflows: write, and Secrets: write — drop those once the legacy setup
# and Action are retired. The v0.4 scan path itself needs no write beyond Checks.
#
# Setup URL: https://<host>/api/github/setup (Redirect on update ON). Turn ON "Request user
# authorization (OAuth) during installation". Leave all GITHUB_APP_* unset to disable the
# App — the dashboard falls back to manual instructions.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# PEM private key on ONE line with literal \n escapes (loader converts them to newlines).
GITHUB_APP_PRIVATE_KEY=
# Webhook secret (consumed by app/api/github/webhooks). Must match the secret set on the
# GitHub App's webhook. In v0.4 it verifies the push/pull_request deliveries that ENQUEUE
# scans, plus the install-lifecycle events. Unset = every delivery is rejected (no scans get
# queued, and uninstall/suspend won't be cleaned up).
GITHUB_APP_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring price for the $29/mo plan — create in Stripe dashboard
STRIPE_PRICE_ID=

# Anthropic (product-owned, server-side only — NEVER NEXT_PUBLIC_)
ANTHROPIC_API_KEY=
# Optional: override the default model (claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# v0.4 backend scan queue (push/PR -> webhook enqueues -> a worker drains the scan_job table
# and runs the scan in-process). Two ways to drain; run either or both:
#  - Standalone worker (primary): `npm run worker` — a long-lived loop, talks to the DB
#    directly, needs NO secret. This is the intended production drainer.
#  - Vercel Cron (belt-and-suspenders): hits /api/cron/drain once a minute (see vercel.json).
#    CRON_SECRET gates that route; Vercel Cron sends it as `Authorization: Bearer <secret>`.
#    Leave unset to disable the cron drain (the standalone worker still drains). The route
#    rejects every request when this is unset, so it never runs unauthenticated.
# Generate: openssl rand -hex 32
CRON_SECRET=
# Set to 1 to enable the TEMPORARY manual scan trigger (/api/dev/scan) used for end-to-end
# testing before the App is live. The route 404s unless this is exactly "1", and still
# requires a logged-in owner of the target installation. Leave unset in production.
ENABLE_DEV_SCAN=

# Optional preview gate — when both are set, the whole site (except API routes)
# is behind HTTP Basic Auth. Leave unset to disable.
PREVIEW_USERNAME=
PREVIEW_PASSWORD=
