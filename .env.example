# Database (Supabase Postgres). MUST use a POOLER host (...pooler.supabase.com) — not the
# direct host (db.[ref].supabase.co), which is IPv6-only and fails on Vercel serverless.
#   Transaction pooler (port 6543) — ideal for serverless
#   Session pooler    (port 5432) — also works on Vercel (IPv4)
# Looks like: postgres://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:6543/postgres
# (code sets prepare:false, so either port is fine)
DATABASE_URL=

# Auth.js
# Generate: openssl rand -base64 32
AUTH_SECRET=
# GitHub OAuth app — register one at github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github (and your prod URL)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# GitHub App — powers one-click repo setup (writes the workflow file + PREFLIGHT_API_KEY
# secret). SEPARATE from the sign-in OAuth app above. Register at github.com/settings/apps/new
# with permissions: Contents: read/write, Workflows: read/write, Secrets: read/write,
# Metadata: read. Setup URL: https://<host>/api/github/setup (Redirect on update ON).
# Turn ON "Request user authorization (OAuth) during installation". Leave all GITHUB_APP_*
# unset to disable one-click setup — the dashboard falls back to the manual instructions.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# PEM private key on ONE line with literal \n escapes (loader converts them to newlines).
GITHUB_APP_PRIVATE_KEY=
# Install-lifecycle webhook secret (consumed by app/api/github/webhooks). Must match the
# secret set on the GitHub App's webhook. Unset = lifecycle deliveries are rejected, so an
# uninstall/suspend won't be cleaned up automatically; one-click setup still works without it.
GITHUB_APP_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring price for the $29/mo plan — create in Stripe dashboard
STRIPE_PRICE_ID=

# Anthropic (product-owned, server-side only — NEVER NEXT_PUBLIC_)
ANTHROPIC_API_KEY=
# Optional: override the default model (claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional preview gate — when both are set, the whole site (except API routes)
# is behind HTTP Basic Auth. Leave unset to disable.
PREVIEW_USERNAME=
PREVIEW_PASSWORD=
